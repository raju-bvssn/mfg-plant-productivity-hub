    global boolean canCreateUser(Auth.UserData data) {        
        return false;
    }

    global User createUser(Id portalId, Auth.UserData data){
        if(!canCreateUser(data)) {
            //Returning null or throwing an exception fails the SSO flow
            extractTokenInfo(data);
            List<User> users = [SELECT Id FROM User WHERE  IsActive = true AND (FederationIdentifier =: data.identifier ) ] ;
             if(null == users || users.IsEmpty()){
                System.debug('user is null');
                User kmUser = createKMUser(data);
                if(null != kmUser){
                    UpdateUserAttributes(kmUser.Id, portalId, data,true); 
                }
                return kmUser;
            }    
           	 User u = users.get(0);
             UpdateUserAttributes(u.Id, portalId, data,false);    
	         return u;              
        }else return null;
    }

    global void updateUser(Id userId, Id portalId, Auth.UserData data){
        extractTokenInfo(data);
        UpdateUserAttributes(userid, portalId, data,false);
      
    }
    
    private void extractTokenInfo(Auth.UserData data){        
       system.debug('attribute values in update user'+ '==' + data.attributeMap.values().size());
        for(String key: data.attributeMap.keySet()){
            System.debug('key: ' + key + '  Value: ' + data.attributeMap.get(key));
            log+= key + '===' +  data.attributeMap.get(key) + '----\n';
            accesstoken = key == 'access_token'? data.attributeMap.get(key) : accesstoken;
            idtoken = key == 'id_token'? data.attributeMap.get(key) : idtoken;
            user_roles = key == 'user_roles'? data.attributeMap.get(key) : user_roles;
            auth_code = key == 'auth_code'? data.attributeMap.get(key) : auth_code;
            refresh_token = key == 'refresh_token'? data.attributeMap.get(key) : refresh_token;
            gm_id = key == 'gm_id'? data.attributeMap.get(key) : gm_id;
            displayName = key == 'displayName'? data.attributeMap.get(key) : displayName;
            gmin = key == 'gmin'? data.attributeMap.get(key) : gmin;
        }
    }
    
    private void UpdateUserAttributes(Id userId, Id portalId, Auth.UserData data, Boolean isUpdateUser){  
        List<User> currentuserList = [Select Id, ProfileId, Persona__c,CallCenterId From User Where Id =: userId];
        if(null !=currentuserList && !currentuserList.isEmpty()){            
            UserProvisioningUtil util = new UserProvisioningUtil();
            User currentuser =  currentuserList.get(0);
            currentuser.Persona__c = user_roles;
            util.provisionUserWithProfileAndPermsets(currentuser,isUpdateUser);
            OnStar_Auth__c onStarAuth = new OnStar_Auth__c();
            onStarAuth.UserID__c = userId;
            onStarAuth.Access_Token__c = accesstoken;
            onStarAuth.Id_Token__c  = idtoken;
            onStarAuth.Auth_Code__c = auth_code;
            onStarAuth.Refresh_Token__c = refresh_token;
            onstarAuth.GM_Id__c = gm_id;
            try{
                SSOLogEnqueue ssolog = new SSOLogEnqueue(onstarAuth);
                System.enqueueJob(ssolog);
            }
            catch(Exception e)
            {
                log+= 'onStarAuth DML exception'+ e.getMessage();
                String errorMsg = String.format('Exception occurred in {0}: {1}', new List<String>{'UserRegistrationHandler-UpdateUserAttributes', e.getMessage()});
            }
            SSOLogEnqueue ssolog = new SSOLogEnqueue(log);
            System.enqueueJob(ssolog);
        }    
    }
    
     global User createKMUser(Auth.UserData data){
        // create KM user 
        User user = null;
        try{            
            // kmusers_profile__c customSetting = kmusers_profile__c.getOrgDefaults();
            String profileName =  'GM Base User';
            List<Profile> profiles = [SELECT Id FROM Profile WHERE Name=:profileName];
            System.debug('Custom settings profile name <<< '+profileName); 
            // if(null !=profiles && !profiles.isEmpty() && doesUserHaveAnyKMPersona()){
            if(null !=profiles && !profiles.isEmpty()){
                user =  new user();
                Profile p = profiles.get(0);
                System.Domain domain = System.DomainParser.parse(URL.getOrgDomainUrl());
                String domainStr = String.isNotBlank(String.valueOf(domain.getSandboxName())) ? '.'+String.valueOf(domain.getSandboxName()) : '.ocrm';
                System.debug('domainStr is <<< '+domainStr);
                String displayName = (!String.isBlank(displayName) && displayName.length() >=33 )? displayName.substring(0,33) : displayName ;
                user.IsActive = true;
                user.username = data.email+domainStr;
                // Replace "@ext.pp.gm.com" with "@gm.com" for email only
                String normalizedEmail = data.email;
                if (String.isNotBlank(normalizedEmail) && normalizedEmail.endsWith('@ext.pp.gm.com')) {
                    normalizedEmail = normalizedEmail.replace('@ext.pp.gm.com', '@gm.com');
                }
                user.email = normalizedEmail;          
                user.FirstName = data.firstName;
                user.LastName = data.lastName;
                user.alias = gm_id;
                user.FederationIdentifier = gm_id;
                user.TimeZoneSidKey = TIME_ZONE; 
                user.LocaleSidKey = LOCALE;
                user.LanguageLocaleKey = LOCALE;
                user.EmailEncodingKey = EMAIL_ENCODING;
                user.ProfileId = p.Id;
                user.Persona__c = user_roles;
                insert user;
                log+='=== inserted user' +  user.Id +'----\n';
                System.debug(' user <<< '+user);
            }
        }catch(Exception e){
            System.debug('Exception occurred in createKMUser '+e.getMessage());
            String errorMsg = String.format('Exception occurred in {0}: {1}', new List<String>{'UserRegistrationHandler-createKMUser', e.getMessage()});
        }
       return user;
   } 

