/**
 * @description Invocable method for processing approval decisions from Flow
 * @author Generated by Claude Code
 * @date 2026-06-07
 */
public with sharing class FlowApprovalProcessor {

    @InvocableMethod(label='Process Approval Decision' description='Approves or rejects a pending approval request')
    public static List<Result> processApproval(List<Request> requests) {
        List<Result> results = new List<Result>();

        for (Request req : requests) {
            Result result = new Result();

            try {
                // Create the approval request
                Approval.ProcessWorkitemRequest approvalReq = new Approval.ProcessWorkitemRequest();
                approvalReq.setWorkitemId(req.workItemId);
                approvalReq.setComments(req.comments);

                // Set the action based on user selection
                if (req.action == 'Approve') {
                    approvalReq.setAction('Approve');
                } else if (req.action == 'Reject') {
                    approvalReq.setAction('Reject');
                } else {
                    result.isSuccess = false;
                    result.errorMessage = 'Invalid action specified. Must be Approve or Reject.';
                    results.add(result);
                    continue;
                }

                // Process the approval
                Approval.ProcessResult approvalResult = Approval.process(approvalReq);

                if (approvalResult.isSuccess()) {
                    result.isSuccess = true;
                    result.message = 'Record has been ' + (req.action == 'Approve' ? 'approved' : 'rejected') + ' successfully.';
                } else {
                    result.isSuccess = false;
                    String errorMsg = 'Error processing approval: ';
                    for (Database.Error error : approvalResult.getErrors()) {
                        errorMsg += error.getMessage() + ' ';
                    }
                    result.errorMessage = errorMsg;
                }

            } catch (Exception e) {
                result.isSuccess = false;
                result.errorMessage = 'Error processing approval: ' + e.getMessage();
            }

            results.add(result);
        }

        return results;
    }

    /**
     * Input parameters for the invocable method
     */
    public class Request {
        @InvocableVariable(label='Work Item ID' required=true)
        public String workItemId;

        @InvocableVariable(label='Action (Approve/Reject)' required=true)
        public String action;

        @InvocableVariable(label='Comments' required=false)
        public String comments;
    }

    /**
     * Output parameters from the invocable method
     */
    public class Result {
        @InvocableVariable(label='Is Success')
        public Boolean isSuccess;

        @InvocableVariable(label='Success Message')
        public String message;

        @InvocableVariable(label='Error Message')
        public String errorMessage;

        public Result() {
            this.isSuccess = false;
            this.message = '';
            this.errorMessage = '';
        }
    }
}