          "name" : "Jan_Value",
          "label" : "Jan",
          "formulaExpression" : "case\n    when Jan_Number__c != 0 then round(Jan_Number__c, 0) || ''\n    when Jan_Decimal__c != 0 then round(Jan_Decimal__c, 1) || ''\n    when Jan_Percent__c != 0 then round(Jan_Percent__c, 2) || '%'\n    else '0'\nend",
          "precision" : 255,
          "defaultValue" : "0"
