    "TO_MEASURE0" : {
      "action" : "typeCast",
      "sources" : [ "JOIN0" ],
      "parameters" : {
        "fields" : [ {
          "name" : "GWB_Year.Year__c",
          "newProperties" : {
            "label" : "Target Year",
            "name" : "Target_Year",
            "typeProperties" : {
              "type" : "NUMBER",
              "scale" : 0,
              "precision" : 4
            }
          }
        } ]
      }
    },
    "FORMULA0" : {
      "action" : "formula",
      "sources" : [ "TO_MEASURE0" ],
      "parameters" : {
        "expressionType" : "SQL",
        "fields" : [ {
          "type" : "TEXT",
          "name" : "Year_In_Scope",
          "label" : "Year In Scope",
          "formulaExpression" : "case \n\twhen (Target_Year = year(now()) OR Target_Year = year(now()) + 1)\n\tthen 'Yes'\n\telse\n\t'No'\nend",
          "precision" : 255,
          "defaultValue" : ""
        } ]
      }
    },
    "FORMULA1" : {
      "action" : "formula",
      "sources" : [ "FILTER0" ],
      "parameters" : {
        "expressionType" : "SQL",
        "fields" : [ {
          "type" : "TEXT",
          "name" : "Label_Driver",
          "label" : "Label/Driver",
          "formulaExpression" : "coalesce(Parameter__c, Driver__c)",
          "precision" : 255,
          "defaultValue" : ""
        } ]
      }
    },
    "FORMULA2" : {
