<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Restrict_Plant_Update</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT($Setup.GWB_Switch__c.Bypass_VRs__c),
    NOT(ISNEW()),
    ISCHANGED(Plant__c),
    OR(
        $Permission.Central_Admin,
        $Permission.Regional_Admin
    )
)</errorConditionFormula>
    <errorMessage>Plant value cannot be updated.</errorMessage>
</ValidationRule>
