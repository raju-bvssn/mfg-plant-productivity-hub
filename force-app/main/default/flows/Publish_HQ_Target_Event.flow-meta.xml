<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <label>Publish HQ Target Event</label>
    <description>After HQ Target is created or updated with a Target FTE, publishes PlantIQ_Target_Set__e Platform Event for MuleSoft to pick up. Apex Queueable (LaunchRecommendationAction) is kept as a fallback — re-enable the actionCalls element if MuleSoft is unavailable.</description>
    <status>Active</status>
    <processType>AutoLaunchedFlow</processType>

    <start>
        <locationX>176</locationX>
        <locationY>50</locationY>
        <object>GWB_HQ_Target__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Target_FTE__c</field>
            <operator>GreaterThan</operator>
            <value>
                <numberValue>0.0</numberValue>
            </value>
        </filters>
        <connector>
            <targetReference>Publish_Platform_Event</targetReference>
        </connector>
    </start>

    <!-- PRIMARY PATH: Publish Platform Event for MuleSoft to consume -->
    <recordCreates>
        <name>Publish_Platform_Event</name>
        <label>Publish PlantIQ Target Set Event</label>
        <locationX>176</locationX>
        <locationY>200</locationY>
        <inputAssignments>
            <field>Target_Id__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Plant_Code__c</field>
            <value>
                <elementReference>$Record.Plant__r.Plant_Code__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Shop_Name__c</field>
            <value>
                <elementReference>$Record.Plant_Shop__r.Name</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Quarter__c</field>
            <value>
                <elementReference>$Record.Quarter__c</elementReference>
            </value>
        </inputAssignments>
        <object>PlantIQ_Target_Set__e</object>
    </recordCreates>

    <!-- FALLBACK (disabled): Apex Queueable path — re-enable by connecting start to Launch_Recommendation -->
    <actionCalls>
        <name>Launch_Recommendation</name>
        <label>Launch PlantIQ Recommendation (Apex Fallback)</label>
        <locationX>440</locationX>
        <locationY>200</locationY>
        <actionName>LaunchRecommendationAction</actionName>
        <actionType>apex</actionType>
        <inputParameters>
            <name>targetId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
    </actionCalls>
</Flow>
