<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <label>Publish HQ Target Event</label>
    <description>After HQ Target is created or updated with a Target FTE, publish PlantIQ_Target_Set__e to trigger Agentforce recommendation chain</description>
    <status>Active</status>
    <processType>AutoLaunchedFlow</processType>

    <start>
        <locationX>176</locationX>
        <locationY>50</locationY>
        <object>GWB_HQ_Target__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Target_FTE__c</field>
            <operator>GreaterThan</operator>
            <value>
                <numberValue>0.0</numberValue>
            </value>
        </filters>
        <connector>
            <targetReference>Publish_Target_Event</targetReference>
        </connector>
    </start>

    <recordCreates>
        <name>Publish_Target_Event</name>
        <label>Publish Platform Event</label>
        <locationX>176</locationX>
        <locationY>200</locationY>
        <inputAssignments>
            <field>Target_Id__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Quarter__c</field>
            <value>
                <elementReference>$Record.Quarter__c</elementReference>
            </value>
        </inputAssignments>
        <object>PlantIQ_Target_Set__e</object>
        <storeOutputAutomatically>false</storeOutputAutomatically>
    </recordCreates>
</Flow>
