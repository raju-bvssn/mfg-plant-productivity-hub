<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Temporary_Requires_Dates</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Idea_Type__c, &quot;Temporary&quot;), OR(ISBLANK(Start_Date__c), ISBLANK(End_Date__c)))</errorConditionFormula>
    <errorMessage>Temporary initiatives require both a Start Date and End Date.</errorMessage>
</ValidationRule>
